[PrefixDeclaration] 
:               http://example.com/idmp-demo/
idmp-mprd:      https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11615-MedicinalProducts/
idmp-sub:       https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO11238-Substances/
idmp-dtp:       https://spec.pistoiaalliance.org/idmp/ontology/ISO/ISO21090-HarmonizedDatatypes/
idmp-nara:      https://spec.pistoiaalliance.org/idmp/ontology/ISO/NorthAmericanJurisdiction/NorthAmericanRegistrationAuthorities/
idmp-eura:      https://spec.pistoiaalliance.org/idmp/ontology/ISO/EuropeanJurisdiction/EuropeanRegistrationAuthorities/
cmns-id:        https://www.omg.org/spec/Commons/Identifiers/
cmns-dsg:       https://www.omg.org/spec/Commons/Designators/
cmns-rlcmp:     https://www.omg.org/spec/Commons/RolesAndCompositions/
cmns-col:       https://www.omg.org/spec/Commons/Collections/
cmns-cls:       https://www.omg.org/spec/Commons/Classifiers/
cmns-txt:       https://www.omg.org/spec/Commons/TextDatatype/
cmns-qtu:       https://www.omg.org/spec/Commons/QuantitiesAndUnits/
lcc-639-1:      https://www.omg.org/spec/LCC/Languages/ISO639-1-LanguageCodes/
rdf:            http://www.w3.org/1999/02/22-rdf-syntax-ns#
rdfs:           http://www.w3.org/2000/01/rdf-schema#
xsd:            http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[

mappingId GsrsSubstance
target :gsrs/substance/{gsrs_uuid} a idmp-sub:Substance .
source SELECT gsrs_uuid
       FROM postgres.gsrs.substance
       WHERE status = 'approved'

mappingId GsrsChemicalSubstance
target :gsrs/substance/{gsrs_uuid} a idmp-sub:ChemicalSubstance .
source SELECT gsrs_uuid
       FROM postgres.gsrs.substance
       WHERE status = 'approved'
         AND substance_class = 'chemical'

mappingId GsrsProteinSubstance
target :gsrs/substance/{gsrs_uuid} a idmp-sub:ProteinSubstance .
source SELECT gsrs_uuid
       FROM postgres.gsrs.substance
       WHERE status = 'approved'
         AND substance_class = 'protein'

mappingId GsrsNucleicAcidSubstance
target :gsrs/substance/{gsrs_uuid} a idmp-sub:NucleicAcidSubstance .
source SELECT gsrs_uuid
       FROM postgres.gsrs.substance
       WHERE status = 'approved'
         AND substance_class = 'nucleicAcid'

mappingId GsrsPolymerSubstance
target :gsrs/substance/{gsrs_uuid} a idmp-sub:PolymerSubstance .
source SELECT gsrs_uuid
       FROM postgres.gsrs.substance
       WHERE status = 'approved'
         AND substance_class = 'polymer'

mappingId GsrsMixtureSubstance
target :gsrs/substance/{gsrs_uuid} a idmp-sub:Mixture .
source SELECT gsrs_uuid
       FROM postgres.gsrs.substance
       WHERE status = 'approved'
         AND substance_class = 'mixture'

mappingId GsrsStructurallyDiverseSubstance
target :gsrs/substance/{gsrs_uuid} a idmp-sub:StructurallyDiverseSubstance .
source SELECT gsrs_uuid
       FROM postgres.gsrs.substance
       WHERE status = 'approved'
         AND substance_class = 'structurallyDiverse'

mappingId GsrsSpecifiedSubstance
target :gsrs/substance/{gsrs_uuid} a idmp-sub:SpecifiedSubstance .
source SELECT gsrs_uuid
       FROM postgres.gsrs.substance
       WHERE status = 'approved'
         AND substance_class = 'specifiedSubstanceG1'

mappingId GsrsSubstanceName
target :gsrs/substance-name/{name_uuid} a idmp-sub:SubstanceName ;
           idmp-sub:hasSubstanceNameValue "{name_value}"^^xsd:string .
source SELECT n.name_uuid,
              n.name_value
       FROM postgres.gsrs.substance_name n
       JOIN postgres.gsrs.substance_has_name hn
         ON hn.name_uuid = n.name_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSubstanceHasName
target :gsrs/substance/{gsrs_uuid} idmp-sub:hasSubstanceName :gsrs/substance-name/{name_uuid} .
source SELECT hn.gsrs_uuid,
              hn.name_uuid
       FROM postgres.gsrs.substance_has_name hn
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSubstanceNameTypeCommon
target :gsrs/substance-name/{name_uuid} idmp-sub:hasSubstanceNameType idmp-sub:SubstanceNameClassifier-CommonName .
source SELECT n.name_uuid
       FROM postgres.gsrs.substance_name n
       JOIN postgres.gsrs.substance_has_name hn
         ON hn.name_uuid = n.name_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'
         AND n.name_type = 'cn'

mappingId GsrsSubstanceNameTypeSystematic
target :gsrs/substance-name/{name_uuid} idmp-sub:hasSubstanceNameType idmp-sub:SubstanceNameClassifier-SystematicName .
source SELECT n.name_uuid
       FROM postgres.gsrs.substance_name n
       JOIN postgres.gsrs.substance_has_name hn
         ON hn.name_uuid = n.name_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'
         AND n.name_type = 'sys'

mappingId GsrsSubstanceNameTypeCompanyCode
target :gsrs/substance-name/{name_uuid} idmp-sub:hasSubstanceNameType idmp-sub:SubstanceNameClassifier-CompanyCode .
source SELECT n.name_uuid
       FROM postgres.gsrs.substance_name n
       JOIN postgres.gsrs.substance_has_name hn
         ON hn.name_uuid = n.name_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'
         AND n.name_type = 'cd'

mappingId GsrsSubstanceNameTypeOfficial
target :gsrs/substance-name/{name_uuid} idmp-sub:hasSubstanceNameType idmp-sub:SubstanceNameClassifier-OfficialName .
source SELECT n.name_uuid
       FROM postgres.gsrs.substance_name n
       JOIN postgres.gsrs.substance_has_name hn
         ON hn.name_uuid = n.name_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'
         AND n.name_type = 'of'

mappingId GsrsSubstanceNameTypeBrand
target :gsrs/substance-name/{name_uuid} idmp-sub:hasSubstanceNameType idmp-sub:SubstanceNameClassifier-BrandName .
source SELECT n.name_uuid
       FROM postgres.gsrs.substance_name n
       JOIN postgres.gsrs.substance_has_name hn
         ON hn.name_uuid = n.name_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'
         AND n.name_type = 'bn'

mappingId GsrsSubstanceNameDomain
target :gsrs/substance-name-domain/{domain_key} a idmp-sub:SubstanceNameDomain ;
           rdfs:label "{domain_value}"^^xsd:string ;
           cmns-txt:hasTextValue "{domain_value}"^^xsd:string .
source SELECT d.domain_key,
              MIN(d.domain_value) AS domain_value
       FROM postgres.gsrs.substance_name_domain d
       JOIN postgres.gsrs.substance_name_has_domain hd
         ON hd.domain_key = d.domain_key
       JOIN postgres.gsrs.substance_has_name hn
         ON hn.name_uuid = hd.name_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'
       GROUP BY d.domain_key

mappingId GsrsSubstanceNameHasDomain
target :gsrs/substance-name/{name_uuid} idmp-sub:hasSubstanceNameDomain :gsrs/substance-name-domain/{domain_key} .
source SELECT hd.name_uuid,
              hd.domain_key
       FROM postgres.gsrs.substance_name_has_domain hd
       JOIN postgres.gsrs.substance_has_name hn
         ON hn.name_uuid = hd.name_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSubstanceNameLanguage
target :gsrs/substance-name/{name_uuid} idmp-dtp:hasLanguageCode lcc-639-1:{language_key} .
source SELECT hl.name_uuid,
              hl.language_key
       FROM postgres.gsrs.substance_name_has_language hl
       JOIN postgres.gsrs.substance_has_name hn
         ON hn.name_uuid = hl.name_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hn.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSubstanceCode
target :gsrs/substance-code/{code_uuid} a idmp-sub:SubstanceCode .
source SELECT c.code_uuid
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'
         AND NOT (
           c.code_system IN ('FDA UNII', 'CAS', 'CHEBI', 'MESH')
           OR (
             c.code_system = 'EVMPD'
             AND regexp_like(c.code_value, '^SUB[A-Z0-9]+$')
           )
         )

mappingId GsrsUniqueIngredientNumber
target :gsrs/substance-code/{code_uuid} a idmp-nara:UniqueIngredientNumber .
source SELECT c.code_uuid
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'
         AND c.code_system = 'FDA UNII'

mappingId GsrsCasRegistryNumber
target :gsrs/substance-code/{code_uuid} a idmp-nara:CASRegistryNumber .
source SELECT c.code_uuid
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'
         AND c.code_system = 'CAS'

mappingId GsrsChebiIdentifier
target :gsrs/substance-code/{code_uuid} a idmp-eura:ChemicalEntitiesOfBiologicalInterestIdentifier .
source SELECT c.code_uuid
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'
         AND c.code_system = 'CHEBI'

mappingId GsrsMeshIdentifier
target :gsrs/substance-code/{code_uuid} a idmp-nara:MedicalSubjectHeadingsUniqueIdentifier .
source SELECT c.code_uuid
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'
         AND c.code_system = 'MESH'

mappingId GsrsEudraVigilanceCode
target :gsrs/substance-code/{code_uuid} a idmp-eura:EudraVigilanceCode .
source SELECT c.code_uuid
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'
         AND c.code_system = 'EVMPD'
         AND regexp_like(c.code_value, '^SUB[A-Z0-9]+$')

mappingId GsrsSubstanceCodeIdentifies
target :gsrs/substance-code/{code_uuid} cmns-id:identifies :gsrs/substance/{gsrs_uuid} .
       :gsrs/substance/{gsrs_uuid} cmns-id:isIdentifiedBy :gsrs/substance-code/{code_uuid} .
source SELECT hc.code_uuid,
              hc.gsrs_uuid
       FROM postgres.gsrs.substance_has_code hc
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSubstanceCodeValue
target :gsrs/substance-code/{code_uuid} cmns-txt:hasTextValue "{code_value}"^^xsd:string .
source SELECT c.code_uuid,
              c.code_value
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSubstanceCodeDisplayName
target :gsrs/substance-code/{code_uuid} idmp-dtp:hasDisplayName "{code_text}"^^xsd:string .
source SELECT c.code_uuid,
              c.code_text
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSubstanceCodeReferenceUrl
target :gsrs/substance-code/{code_uuid} idmp-dtp:hasReferenceURL "{code_url}"^^xsd:anyURI .
source SELECT c.code_uuid,
              c.code_url
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'
         AND regexp_like(c.code_url, '^https?://')

mappingId GsrsSubstanceCodeComment
target :gsrs/substance-code/{code_uuid} idmp-sub:hasComment "{comments}"^^xsd:string .
source SELECT c.code_uuid,
              c.comments
       FROM postgres.gsrs.substance_code c
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = c.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsCodeSystem
target :gsrs/code-system/{code_system_key} a idmp-dtp:CodeSystem ;
           cmns-dsg:hasName :gsrs/code-system-name/{code_system_key} .
       :gsrs/code-system-name/{code_system_key} a idmp-dtp:CodeSystemName ;
           cmns-txt:hasTextValue "{code_system}"^^xsd:string .
source SELECT cs.code_system_key,
              MIN(cs.code_system) AS code_system
       FROM postgres.gsrs.code_system cs
       JOIN postgres.gsrs.substance_code_in_code_system cics
         ON cics.code_system_key = cs.code_system_key
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = cics.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'
       GROUP BY cs.code_system_key

mappingId GsrsSubstanceCodeInCodeSystem
target :gsrs/substance-code/{code_uuid} cmns-col:isMemberOf :gsrs/code-system/{code_system_key} .
source SELECT cs.code_uuid,
              cs.code_system_key
       FROM postgres.gsrs.substance_code_in_code_system cs
       JOIN postgres.gsrs.substance_has_code hc
         ON hc.code_uuid = cs.code_uuid
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hc.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsMolecularStructure
target :gsrs/molecular-structure/{structure_key} a idmp-sub:MolecularStructure .
source SELECT st.structure_key
       FROM postgres.gsrs.substance_structure st
       JOIN postgres.gsrs.substance_has_structure hs
         ON hs.structure_key = st.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSubstanceHasDefiningStructure
target :gsrs/substance/{gsrs_uuid} idmp-sub:hasDefiningStructure :gsrs/molecular-structure/{structure_key} .
source SELECT hs.gsrs_uuid,
              hs.structure_key
       FROM postgres.gsrs.substance_has_structure hs
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsMolecularStructureIdentifier
target :gsrs/molecular-structure-id/{structure_id} a idmp-sub:MolecularStructureIdentifier ;
           cmns-id:identifies :gsrs/molecular-structure/{structure_key} ;
           cmns-txt:hasTextValue "{structure_id}"^^xsd:string .
       :gsrs/molecular-structure/{structure_key} cmns-id:isIdentifiedBy :gsrs/molecular-structure-id/{structure_id} .
source SELECT st.structure_key,
              st.structure_id
       FROM postgres.gsrs.substance_structure st
       JOIN postgres.gsrs.substance_has_structure hs
         ON hs.structure_key = st.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'
         AND st.structure_id IS NOT NULL

mappingId GsrsMolecularFormula
target :gsrs/molecular-formula/{structure_key} a idmp-sub:MolecularFormula ;
           cmns-txt:hasTextValue "{molecular_formula}"^^xsd:string .
source SELECT st.structure_key,
              st.molecular_formula
       FROM postgres.gsrs.substance_structure st
       JOIN postgres.gsrs.substance_has_structure hs
         ON hs.structure_key = st.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'
         AND st.molecular_formula IS NOT NULL

mappingId GsrsSubstanceHasMolecularFormula
target :gsrs/substance/{gsrs_uuid} idmp-sub:hasDefiningMolecularFormula :gsrs/molecular-formula/{structure_key} .
source SELECT hf.gsrs_uuid,
              hf.structure_key
       FROM postgres.gsrs.substance_has_molecular_formula hf
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hf.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsMolecularWeight
target :gsrs/molecular-weight/{structure_key} a idmp-sub:MolecularWeight ;
           cmns-qtu:hasNumericValue "{molecular_weight}"^^xsd:decimal .
source SELECT st.structure_key,
              st.molecular_weight
       FROM postgres.gsrs.substance_structure st
       JOIN postgres.gsrs.substance_has_structure hs
         ON hs.structure_key = st.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'
         AND st.molecular_weight IS NOT NULL

mappingId GsrsSubstanceHasMolecularWeight
target :gsrs/substance/{gsrs_uuid} idmp-sub:hasDefiningMolecularWeight :gsrs/molecular-weight/{structure_key} .
source SELECT hw.gsrs_uuid,
              hw.structure_key
       FROM postgres.gsrs.substance_has_molecular_weight hw
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hw.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSmiles
target :gsrs/smiles/{structure_key} a idmp-sub:SMILES ;
           idmp-sub:hasSMILESValue "{smiles}"^^xsd:string .
source SELECT st.structure_key,
              st.smiles
       FROM postgres.gsrs.substance_structure st
       JOIN postgres.gsrs.substance_has_structure hs
         ON hs.structure_key = st.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'
         AND st.smiles IS NOT NULL

mappingId GsrsMolecularStructureHasSmiles
target :gsrs/molecular-structure/{structure_key} idmp-sub:hasSMILES :gsrs/smiles/{structure_key} .
source SELECT hs.structure_key
       FROM postgres.gsrs.molecular_structure_has_smiles hs
       JOIN postgres.gsrs.substance_has_structure hst
         ON hst.structure_key = hs.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hst.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsMolfile
target :gsrs/molfile/{structure_key} a idmp-sub:Molfile ;
           idmp-sub:hasStructuralRepresentationText "{molfile}"^^xsd:string .
source SELECT st.structure_key,
              st.molfile
       FROM postgres.gsrs.substance_structure st
       JOIN postgres.gsrs.substance_has_structure hs
         ON hs.structure_key = st.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'
         AND st.molfile IS NOT NULL

mappingId GsrsMolecularStructureHasMolfile
target :gsrs/molecular-structure/{structure_key} idmp-sub:hasMolfile :gsrs/molfile/{structure_key} .
source SELECT hm.structure_key
       FROM postgres.gsrs.molecular_structure_has_molfile hm
       JOIN postgres.gsrs.substance_has_structure hs
         ON hs.structure_key = hm.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'

mappingId GsrsSubstanceStereochemistry
target :gsrs/substance/{gsrs_uuid} idmp-sub:hasStereochemistry idmp-sub:{stereochemistry_classifier} .
source SELECT hs.gsrs_uuid,
              st.stereochemistry_classifier
       FROM postgres.gsrs.substance_structure st
       JOIN postgres.gsrs.substance_has_structure hs
         ON hs.structure_key = st.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'
         AND st.stereochemistry_classifier IS NOT NULL

mappingId GsrsSubstanceOpticalActivity
target :gsrs/substance/{gsrs_uuid} idmp-sub:hasOpticalActivity idmp-sub:{optical_activity_classifier} .
source SELECT hs.gsrs_uuid,
              st.optical_activity_classifier
       FROM postgres.gsrs.substance_structure st
       JOIN postgres.gsrs.substance_has_structure hs
         ON hs.structure_key = st.structure_key
       JOIN postgres.gsrs.substance s
         ON s.gsrs_uuid = hs.gsrs_uuid
       WHERE s.status = 'approved'
         AND st.optical_activity_classifier IS NOT NULL

mappingId GsrsSubstanceRelationship
target :gsrs/substance-relationship/{relationship_uuid} a idmp-sub:SubstanceRelationship .
source SELECT r.relationship_uuid
       FROM postgres.gsrs.substance_relationship r
       JOIN postgres.gsrs.substance_relationship_has_subject hs
         ON hs.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_related hr
         ON hr.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance source_substance
         ON source_substance.gsrs_uuid = hs.source_gsrs_uuid
       JOIN postgres.gsrs.substance related_substance
         ON related_substance.gsrs_uuid = hr.related_gsrs_uuid
       WHERE source_substance.status = 'approved'
         AND related_substance.status = 'approved'

mappingId GsrsSubstanceRelationshipSubject
target :gsrs/substance-relationship/{relationship_uuid} idmp-sub:hasSubjectSubstance :gsrs/substance/{source_gsrs_uuid} .
source SELECT hs.relationship_uuid,
              hs.source_gsrs_uuid
       FROM postgres.gsrs.substance_relationship_has_subject hs
       JOIN postgres.gsrs.substance_relationship r
         ON r.relationship_uuid = hs.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_related hr
         ON hr.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance source_substance
         ON source_substance.gsrs_uuid = hs.source_gsrs_uuid
       JOIN postgres.gsrs.substance related_substance
         ON related_substance.gsrs_uuid = hr.related_gsrs_uuid
       WHERE source_substance.status = 'approved'
         AND related_substance.status = 'approved'

mappingId GsrsSubstanceRelationshipRelated
target :gsrs/substance-relationship/{relationship_uuid} idmp-sub:hasRelatedSubstance :gsrs/substance/{related_gsrs_uuid} .
source SELECT hr.relationship_uuid,
              hr.related_gsrs_uuid
       FROM postgres.gsrs.substance_relationship_has_related hr
       JOIN postgres.gsrs.substance_relationship r
         ON r.relationship_uuid = hr.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_subject hs
         ON hs.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance source_substance
         ON source_substance.gsrs_uuid = hs.source_gsrs_uuid
       JOIN postgres.gsrs.substance related_substance
         ON related_substance.gsrs_uuid = hr.related_gsrs_uuid
       WHERE source_substance.status = 'approved'
         AND related_substance.status = 'approved'

mappingId GsrsSubstanceRelationshipCode
target :gsrs/substance-relationship-code/{relationship_type_key} a idmp-sub:SubstanceRelationshipCode ;
           cmns-txt:hasTextValue "{relationship_type}"^^xsd:string .
source SELECT r.relationship_type_key,
              MIN(r.relationship_type) AS relationship_type
       FROM postgres.gsrs.substance_relationship r
       JOIN postgres.gsrs.substance_relationship_has_subject hs
         ON hs.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_related hr
         ON hr.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance source_substance
         ON source_substance.gsrs_uuid = hs.source_gsrs_uuid
       JOIN postgres.gsrs.substance related_substance
         ON related_substance.gsrs_uuid = hr.related_gsrs_uuid
       WHERE source_substance.status = 'approved'
         AND related_substance.status = 'approved'
         AND r.relationship_type_key IS NOT NULL
       GROUP BY r.relationship_type_key

mappingId GsrsSubstanceRelationshipCodeLink
target :gsrs/substance-relationship/{relationship_uuid} cmns-dsg:isSignifiedBy :gsrs/substance-relationship-code/{relationship_type_key} .
       :gsrs/substance-relationship-code/{relationship_type_key} cmns-dsg:denotes :gsrs/substance-relationship/{relationship_uuid} .
source SELECT hc.relationship_uuid,
              hc.relationship_type_key
       FROM postgres.gsrs.substance_relationship_has_code hc
       JOIN postgres.gsrs.substance_relationship r
         ON r.relationship_uuid = hc.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_subject hs
         ON hs.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_related hr
         ON hr.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance source_substance
         ON source_substance.gsrs_uuid = hs.source_gsrs_uuid
       JOIN postgres.gsrs.substance related_substance
         ON related_substance.gsrs_uuid = hr.related_gsrs_uuid
       WHERE source_substance.status = 'approved'
         AND related_substance.status = 'approved'

mappingId GsrsSubstanceRelationshipInteractionType
target :gsrs/substance-relationship-type/{interaction_type_key} a idmp-sub:SubstanceRelationshipType ;
           cmns-txt:hasTextValue "{interaction_type}"^^xsd:string .
source SELECT r.interaction_type_key,
              MIN(r.interaction_type) AS interaction_type
       FROM postgres.gsrs.substance_relationship r
       JOIN postgres.gsrs.substance_relationship_has_subject hs
         ON hs.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_related hr
         ON hr.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance source_substance
         ON source_substance.gsrs_uuid = hs.source_gsrs_uuid
       JOIN postgres.gsrs.substance related_substance
         ON related_substance.gsrs_uuid = hr.related_gsrs_uuid
       WHERE source_substance.status = 'approved'
         AND related_substance.status = 'approved'
         AND r.interaction_type_key IS NOT NULL
       GROUP BY r.interaction_type_key

mappingId GsrsSubstanceRelationshipInteractionTypeLink
target :gsrs/substance-relationship/{relationship_uuid} cmns-cls:isClassifiedBy :gsrs/substance-relationship-type/{interaction_type_key} .
       :gsrs/substance-relationship-type/{interaction_type_key} cmns-cls:classifies :gsrs/substance-relationship/{relationship_uuid} .
source SELECT hit.relationship_uuid,
              hit.interaction_type_key
       FROM postgres.gsrs.substance_relationship_has_interaction_type hit
       JOIN postgres.gsrs.substance_relationship r
         ON r.relationship_uuid = hit.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_subject hs
         ON hs.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_related hr
         ON hr.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance source_substance
         ON source_substance.gsrs_uuid = hs.source_gsrs_uuid
       JOIN postgres.gsrs.substance related_substance
         ON related_substance.gsrs_uuid = hr.related_gsrs_uuid
       WHERE source_substance.status = 'approved'
         AND related_substance.status = 'approved'

mappingId GsrsSubstanceRelationshipComment
target :gsrs/substance-relationship/{relationship_uuid} idmp-sub:hasComment "{comments}"^^xsd:string .
source SELECT r.relationship_uuid,
              r.comments
       FROM postgres.gsrs.substance_relationship r
       JOIN postgres.gsrs.substance_relationship_has_subject hs
         ON hs.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance_relationship_has_related hr
         ON hr.relationship_uuid = r.relationship_uuid
       JOIN postgres.gsrs.substance source_substance
         ON source_substance.gsrs_uuid = hs.source_gsrs_uuid
       JOIN postgres.gsrs.substance related_substance
         ON related_substance.gsrs_uuid = hr.related_gsrs_uuid
       WHERE source_substance.status = 'approved'
         AND related_substance.status = 'approved'
         AND r.comments IS NOT NULL

